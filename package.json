{
  "name": "next_teamdev_template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check": "npx prettier --check \"src/**/*.{css,js,ts,jsx,tsx}\"",
    "format": "npx prettier --write \"src/**/*.{css,js,ts,jsx,tsx}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{css,js,ts,jsx,tsx}": [
      "prettier --write \"src/**/*.{css,js,ts,jsx,tsx}\"",
      "eslint . --max-warnings 0 --no-warn-ignored"
    ]
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "3.8.4",
    "typescript": "^5"
  }
}
